NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# 32-byte hex, generate with: openssl rand -hex 32
AUTH_SESSION_SECRET=

# JWT audience. In prod set to the public domain (e.g. builder.circles.garage).
# In dev this defaults to "localhost" if unset.
AUTH_AUDIENCE=

# Gnosis RPC. Public endpoint is OK for cycle 01; swap for a paid SLA endpoint
# before opening to abuse-prone traffic. Server uses it to verify EIP-1271
# Safe signatures; client may use the public one for read-only SDK calls.
GNOSIS_RPC_URL=https://rpc.gnosischain.com
NEXT_PUBLIC_GNOSIS_RPC_URL=https://rpc.gnosischain.com
