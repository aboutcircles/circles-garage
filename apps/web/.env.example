# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Public origin used to build absolute OAuth redirect URLs.
# REQUIRED in any reverse-proxied deployment (DigitalOcean App Platform,
# Vercel preview deployments behind custom domains, anything where the
# incoming Host header is the internal port — e.g. localhost:8080 — rather
# than the public hostname). Without it, /auth/callback computes the
# redirect target from request.nextUrl.origin and the user ends up at
# https://localhost:8080/dashboard.
# Leave empty for local dev (falls back to window.location.origin /
# request.nextUrl.origin which work fine when there's no proxy).
# No trailing slash.
NEXT_PUBLIC_SITE_URL=
